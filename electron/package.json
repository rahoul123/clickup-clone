{
  "name": "collab-creek-electron",
  "version": "1.0.7",
  "main": "main.cjs",
  "author": "Rahoul Khatri",
  "private": true,
  "scripts": {
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com-collabcreek-app",
    "productName": "DigitechIO",
    "directories": {
      "output": "../frontend/release"
    },
    "publish": {
      "provider": "github",
      "owner": "rahoul123",
      "repo": "clickup-clone"
    },
    "win": { "icon": "assets/icon.ico",
      "target": "nsis",
      "artifactName": "${productName}-Setup-${version}.exe"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.exe"
    },
    "files": [
      "main.cjs",
      "preload.cjs"
    ],
    "extraResources": [
      {
        "from": "../.env",
        "to": "."
      }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  }
}
